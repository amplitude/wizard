// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`OutroScreen snapshots > renders the cancel state 1`] = `
"
  ─ Setup cancelled

  Setup cancelled.

  Manual setup: https://amplitude.com/docs/get-started/quickstart

  Press any key to exit
"
`;

exports[`OutroScreen snapshots > renders the error state with a message and docs fallback 1`] = `
"
  ✗ Setup failed

  The agent could not detect your framework. Re-run with --menu to pick one manually.

  → Check your API key and network connection
  → Run the wizard again with --debug for more detail
  → Full log: <tmp>/amplitude-wizard.log (press L to open)
  → Press C to write a sanitized bug report
  → Docs: https://amplitude.com/docs/get-started/quickstart

  Press any key to exit
"
`;

exports[`OutroScreen snapshots > renders the success state with changes + continue link 1`] = `
"
  🎉 Amplitude is live!

  ● Installed @amplitude/analytics-browser
  ● Added .env.local with AMPLITUDE_API_KEY
  ● Added 3 planned events to your tracking plan


  ▸ [1] Open Amplitude (amplitude.com)
    [2] Exit
"
`;
