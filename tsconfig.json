{
  "extends": "./tsconfig.build.json",

  "compilerOptions": {
    "moduleResolution": "node16",
    "module": "node16",
    "types": ["node", "jest"],
    "typeRoots": ["./node_modules/@types", "./types"],
    "declaration": true,
    "resolveJsonModule": true,
    "outDir": "dist"
  },
  "include": [
    "__mocks__/**/*",
    "index.ts",
    "bin.ts",
    "src/**/*",
    "types/**/*"
  ],
  "exclude": [
    "e2e-tests/**/*",
    "features/**/*",
    "src/**/__tests__/**/*",
    "src/**/*.test.ts",
    "src/**/*.spec.ts"
  ],
  "ts-node": {
    "files": true
  }
}
