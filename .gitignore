# ──────────────────────────────────────────────────────────────
# OS junk
# ──────────────────────────────────────────────────────────────
.DS_Store
# macOS AppleDouble resource forks
._*
.Spotlight-V100
.Trashes
Thumbs.db

# ──────────────────────────────────────────────────────────────
# Dependencies & build output
# ──────────────────────────────────────────────────────────────
node_modules/
/dist/
# Anchored to repo root — don't ignore arbitrary `build/` dirs
/build/
/coverage/
/reports/
.eslintcache

# ──────────────────────────────────────────────────────────────
# Logs
# ──────────────────────────────────────────────────────────────
*.log

# ──────────────────────────────────────────────────────────────
# Native / mobile build artifacts (anchored to repo root)
# ──────────────────────────────────────────────────────────────
/ios
/android
/plugins

# ──────────────────────────────────────────────────────────────
# Python (used by some skills / scripts)
# ──────────────────────────────────────────────────────────────
*.pyc
__pycache__/

# ──────────────────────────────────────────────────────────────
# Editors
# ──────────────────────────────────────────────────────────────
.idea/
*.sublime-*
# Personal launch configs; share via docs instead
.vscode/launch.json

# ──────────────────────────────────────────────────────────────
# Secrets & local config
# ──────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
.vercel
# May contain user-specific MCP server secrets
.mcp.json

# ──────────────────────────────────────────────────────────────
# Docs build output
# ──────────────────────────────────────────────────────────────
/docs/_build/
/docs/doctrees/

# ──────────────────────────────────────────────────────────────
# Local scratch / fixtures
# ──────────────────────────────────────────────────────────────
/scratch/
/e2e-tests/fixtures/.tracking/

# ──────────────────────────────────────────────────────────────
# Claude Code local state
# ──────────────────────────────────────────────────────────────
# Ignore everything under .claude/skills/ EXCEPT skills shipped with
# the wizard npm package. The shipped skills land in
# `package.json#files` and drive Claude Code agents through the
# agent-mode protocol. Local-only skills (downloaded / generated by
# tooling) still match this rule.
.claude/skills/*
!.claude/skills/amplitude-setup/
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json
